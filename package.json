{
  "name": "wikileighs",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev --host 127.0.0.1 --port 4321",
    "test:date": "node --experimental-strip-types --test src/lib/date.test.ts",
    "build:project-field": "vite build --config project-field/vite.config.ts",
    "build": "npm run test:date && npm run build:project-field && astro build && node scripts/check-built-today-date.mjs",
    "preview": "astro preview --host 127.0.0.1 --port 4321",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.14.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.0",
    "marked-gfm-heading-id": "^4.1.4",
    "mdast-util-to-string": "^4.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "unist-util-visit": "^5.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "vite": "^7.1.0"
  }
}
