---
import Base from '../../layouts/Base.astro';
import { listTodayPageDates } from '../../lib/vault';

const dates = listTodayPageDates();

interface MonthGroup {
  monthKey: string;
  monthLabel: string;
  entries: Array<{ date: string; weekday: string; dayLabel: string }>;
}

const groups: MonthGroup[] = [];
const monthIndex = new Map<string, MonthGroup>();

for (const date of dates) {
  const parsed = new Date(`${date}T12:00:00-04:00`);
  const monthKey = date.slice(0, 7);
  const monthLabel = parsed.toLocaleDateString('en-US', {
    month: 'long',
    year: 'numeric',
    timeZone: 'America/New_York',
  });
  const weekday = parsed.toLocaleDateString('en-US', {
    weekday: 'long',
    timeZone: 'America/New_York',
  });
  const dayLabel = parsed.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    timeZone: 'America/New_York',
  });
  let group = monthIndex.get(monthKey);
  if (!group) {
    group = { monthKey, monthLabel, entries: [] };
    monthIndex.set(monthKey, group);
    groups.push(group);
  }
  group.entries.push({ date, weekday, dayLabel });
}

const BASE_URL = import.meta.env.BASE_URL;
---
<Base title="Today — Archive" description="All daily snapshots, newest first.">
  <div class="breadcrumb">
    <a href={BASE_URL}>Main page</a> · <a href={`${BASE_URL}today`}>Today</a> · Archive
  </div>
  <article class="article-body">
    <h1>Daily snapshots — archive</h1>
    {dates.length === 0 ? (
      <p style="color: var(--color-muted);"><em>No daily snapshots have been generated yet.</em></p>
    ) : (
      <>
        <p style="color: var(--color-muted);">
          {dates.length} {dates.length === 1 ? 'snapshot' : 'snapshots'}, newest first.
        </p>
        {groups.map(group => (
          <section class="archive-month">
            <h2>{group.monthLabel}</h2>
            <ul class="archive-list">
              {group.entries.map(e => (
                <li>
                  <a href={`${BASE_URL}today/${e.date}/`}>{e.weekday}, {e.dayLabel}</a>
                  <span class="archive-stamp">{e.date}</span>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </>
    )}
  </article>
</Base>

<style is:global>
  .archive-month + .archive-month {
    margin-top: 1.25rem;
  }
  .archive-list {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }
  .archive-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 0.25rem 0;
    border-bottom: 1px dotted var(--color-border-light);
  }
  .archive-list li:last-child {
    border-bottom: none;
  }
  .archive-stamp {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.85em;
    color: var(--color-muted);
  }
</style>
