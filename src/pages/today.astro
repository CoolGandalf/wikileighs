---
import Base from '../layouts/Base.astro';
import { newYorkDateLabel, newYorkDateStamp, shiftDateStamp } from '../lib/date';
import { getTodayPage } from '../lib/vault';

const today = new Date();
const todayPage = getTodayPage(today);
const todayStamp = newYorkDateStamp(today);
const headerDate = newYorkDateLabel(today).replace(/^([^ ]+) /, '$1, ');
const BASE_URL = import.meta.env.BASE_URL;

// Derive yesterday from the New York calendar stamp, not the runner's UTC day.
const yesterdayStamp = shiftDateStamp(todayStamp, -1);
---
<Base title="Today" description={`Daily snapshot for ${headerDate}.`}>
  <div class="breadcrumb"><a href={BASE_URL}>Main page</a> · Today · <a href={`${BASE_URL}today/archive`}>Archive ▸</a></div>
  {todayPage ? (
    <article class="article-body">
      {todayPage.photo && (
        <figure class="today-hero">
          <img src={todayPage.photo} alt={`Today's hero — ${todayPage.created || 'today'}`} loading="lazy" />
        </figure>
      )}
      <p class="today-archive-link"><a href={`${BASE_URL}today/archive`}>↗ All daily snapshots</a></p>
      <Fragment set:html={todayPage.html} />
    </article>
  ) : (
    <article class="article-body">
      <h1>{headerDate}</h1>
      <p style="color: var(--color-muted);">
        <em>Today's snapshot hasn't been generated yet. The next refresh fires at the top of each hour from 7 AM to 11 PM EDT.</em>
      </p>
      <p>
        Meanwhile: <a href={`${BASE_URL}today/${yesterdayStamp}`}>Yesterday's snapshot ▸</a>
      </p>
    </article>
  )}
</Base>
