---
import Base from '../layouts/Base.astro';
import { loadAllArticles } from '../lib/vault';
const all = loadAllArticles().map(a => a.slug);
const BASE_URL = import.meta.env.BASE_URL;
---
<Base title="Random article">
  <article class="article-body">
    <h1>Random article</h1>
    <p>Picking a random article...</p>
    <p><a id="fallback" href={BASE_URL}>If you aren't redirected, click here.</a></p>
  </article>
  <script is:inline define:vars={{ all, BASE_URL }}>
    const slug = all[Math.floor(Math.random() * all.length)];
    if (slug) window.location.replace(BASE_URL + 'wiki/' + slug);
  </script>
</Base>
