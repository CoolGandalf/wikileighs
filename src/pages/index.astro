---
import Base from '../layouts/Base.astro';
import {
  loadAllArticles,
  getTypeCounts,
  getRecentlyUpdated,
  getFeaturedArticle,
  getArticlesByType,
  getTodayPage,
  getLatestUploadHero,
  humanizeType,
  pluralizeType,
} from '../lib/vault';

const all = loadAllArticles();
const typeCounts = getTypeCounts();
const recentlyUpdated = getRecentlyUpdated(8);
const featured = getFeaturedArticle();
const heroPhoto = getLatestUploadHero();

// Today block
const todayDate = new Date();
const todayPage = getTodayPage(todayDate);

function pad2(n: number): string { return n < 10 ? `0${n}` : String(n); }
const todayStamp = `${todayDate.getFullYear()}-${pad2(todayDate.getMonth() + 1)}-${pad2(todayDate.getDate())}`;

// Extract briefing first paragraph from today's bodyMd
function extractBriefingParagraph(bodyMd: string): string {
  const lines = bodyMd.split('\n');
  const idx = lines.findIndex((l) => /^##\s+Briefing/i.test(l.trim()));
  if (idx < 0) return '';
  const buf: string[] = [];
  let started = false;
  for (let i = idx + 1; i < lines.length; i++) {
    const t = lines[i].trim();
    if (!t) {
      if (started) break;
      continue;
    }
    if (t.startsWith('#')) { if (started) break; continue; }
    started = true;
    buf.push(t);
  }
  return buf
    .join(' ')
    .replace(/\[\[([^\]|]+)(?:\|([^\]]+))?\]\]/g, (_: string, tgt: string, alias: string) => alias || tgt)
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[*_`]/g, '')
    .slice(0, 420);
}

function extractTodayStats(bodyMd: string): { voiceMemos: number; photos: number; agentRuns: number | null } {
  const vmMatch = bodyMd.match(/###\s+Voice memos\s+\((\d+)\)/i);
  const voiceMemos = vmMatch ? parseInt(vmMatch[1], 10) : 0;

  const photoCapturesMatch = bodyMd.match(/(\d+)\s+captures?/i);
  const photos = photoCapturesMatch ? parseInt(photoCapturesMatch[1], 10) : 0;

  const agentTotalMatch = bodyMd.match(/(\d+)\s+total\s+runs?/i);
  let agentRuns: number | null = null;
  if (agentTotalMatch) {
    agentRuns = parseInt(agentTotalMatch[1], 10);
  } else {
    // Fallback: count lines like **AgentName** — N runs
    const runLines = bodyMd.match(/\*\*[^*]+\*\*\s*—\s*\d+\s+runs?/g);
    if (runLines && runLines.length > 0) {
      let total = 0;
      for (const l of runLines) {
        const m = l.match(/(\d+)\s+runs?/);
        if (m) total += parseInt(m[1], 10);
      }
      agentRuns = total > 0 ? total : null;
    }
  }

  return { voiceMemos, photos, agentRuns };
}

const todayBriefing = todayPage
  ? (extractBriefingParagraph(todayPage.bodyMd) || todayPage.firstParagraph)
  : '';
const todayStats = todayPage ? extractTodayStats(todayPage.bodyMd) : null;

// Format today's date as "Wednesday April 29 2026"
const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const todayLabel = `${dayNames[todayDate.getDay()]} ${monthNames[todayDate.getMonth()]} ${todayDate.getDate()} ${todayDate.getFullYear()}`;

const categoriesForBrowse = typeCounts
  .map(tc => ({
    ...tc,
    articles: getArticlesByType(tc.type).slice(0, 12),
    total: tc.count,
  }))
  .filter(c => c.articles.length);
const BASE_URL = import.meta.env.BASE_URL;
---
<Base title="Main page">
  <section class="welcome-block">
    <h1 class="welcome-title">Welcome to WikiLeighs,</h1>
    <p style="font-size: 15px; line-height: 1.6;">
      the free encyclopedia that Leigh is writing. {all.length} articles across {typeCounts.length} categories,
      rendered from the <code>notes/</code> subtree of his Obsidian vault.
    </p>
  </section>

  <section class="today-block">
    <h2 class="today-block-heading">Today, {todayLabel}</h2>
    {todayPage ? (
      <div>
        {todayBriefing && <p class="today-briefing">{todayBriefing}</p>}
        {todayStats && (
          <p class="today-stats">
            {todayStats.voiceMemos > 0 && <span>{todayStats.voiceMemos} voice memo{todayStats.voiceMemos !== 1 ? 's' : ''}</span>}
            {todayStats.voiceMemos > 0 && todayStats.photos > 0 && <span class="today-stats-sep"> · </span>}
            {todayStats.photos > 0 && <span>{todayStats.photos} photo{todayStats.photos !== 1 ? 's' : ''}</span>}
            {(todayStats.voiceMemos > 0 || todayStats.photos > 0) && todayStats.agentRuns !== null && <span class="today-stats-sep"> · </span>}
            {todayStats.agentRuns !== null && <span>{todayStats.agentRuns} agent run{todayStats.agentRuns !== 1 ? 's' : ''}</span>}
          </p>
        )}
        <p class="today-read-more">
          <a href={`${BASE_URL}today/${todayStamp}`}>Read full snapshot →</a>
        </p>
      </div>
    ) : (
      <div>
        <p class="today-briefing" style="color: var(--color-muted); font-style: italic;">
          Today's snapshot hasn't generated yet. Next refresh top of the hour.
        </p>
        <p class="today-read-more">
          <a href={`${BASE_URL}today`}>View recent snapshots →</a>
        </p>
      </div>
    )}
  </section>

  <div class="contents-row">
    <div>
      {featured && (
        <section class="featured-block">
          <div class="featured-header">Featured article</div>
          <div class="featured-body">
            {heroPhoto ? (
              <figure class="featured-hero">
                <img src={heroPhoto.src} alt={`Latest upload — ${heroPhoto.date}`} loading="lazy" />
                <figcaption>{heroPhoto.date}</figcaption>
              </figure>
            ) : (
              <div class="featured-image-placeholder" aria-hidden="true"></div>
            )}
            <span class="featured-title"><a href={`${BASE_URL}wiki/${featured.slug}`} style="color: var(--color-link); text-decoration: none;">{featured.title}</a></span>
            {' '}— {featured.firstParagraph}
            {' '}
            <a href={`${BASE_URL}wiki/${featured.slug}`} style="color: var(--color-link); text-decoration: none;">(continue reading...)</a>
            <div style="clear: both;"></div>
          </div>
        </section>
      )}

      {recentlyUpdated.length > 0 && (
        <section class="browse-block recently-updated-block">
          <h2 class="browse-title">Recently updated</h2>
          <ul class="recently-updated-list">
            {recentlyUpdated.map(a => (
              <li>
                <a href={`${BASE_URL}wiki/${a.slug}`}>{a.title}</a>
                <span class="tag-chip">{humanizeType(a.type)}</span>
                <span class="date">{a.updated}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="browse-block">
        <h2 class="browse-title">Browse by category</h2>
        <div class="browse-grid">
          {categoriesForBrowse.map(cat => (
            <div class="browse-category">
              <h3><a href={`${BASE_URL}category/${cat.type}`} style="color: inherit; text-decoration: none;">{pluralizeType(cat.type)}</a></h3>
              <ul>
                {cat.articles.map(a => (
                  <li>
                    <a href={`${BASE_URL}wiki/${a.slug}`}>{a.title}</a>
                    <span class="type"> — {humanizeType(a.type)}</span>
                  </li>
                ))}
                {cat.total > cat.articles.length && (
                  <li><a href={`${BASE_URL}category/${cat.type}`} style="color: var(--color-muted);">...and {cat.total - cat.articles.length} more</a></li>
                )}
              </ul>
            </div>
          ))}
        </div>
      </section>
    </div>

    <div>
      <section class="card">
        <div class="card-header">About WikiLeighs</div>
        <div class="card-body">
          <p>
            WikiLeighs is a personal encyclopedia — everything I'm consuming, doing, and thinking about.
            It's Leigh's Obsidian vault, rendered as a browsable web reader inspired by Wikipedia and Farzapedia.
          </p>
          <p style="margin-top: 0.5rem;">
            <a href={`${BASE_URL}about`} style="color: var(--color-link); text-decoration: none;">See the About page →</a>
          </p>
        </div>
      </section>

      <section class="card">
        <div class="card-header">By the numbers</div>
        <div class="card-body">
          <ul>
            <li><span>Total articles</span><span class="date">{all.length}</span></li>
            <li><span>Categories</span><span class="date">{typeCounts.length}</span></li>
            {typeCounts.slice(0, 6).map(tc => (
              <li>
                <span><a href={`${BASE_URL}category/${tc.type}`} style="color: var(--color-link); text-decoration: none;">{pluralizeType(tc.type)}</a></span>
                <span class="date">{tc.count}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    </div>
  </div>
</Base>
