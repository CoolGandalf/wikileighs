---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import LeftRail from '../components/LeftRail.astro';

interface Props {
  title: string;
  description?: string;
  activeType?: string;
}

const { title, description = 'WikiLeighs — the personal encyclopedia', activeType } = Astro.props;
const BASE_URL = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <meta name="googlebot" content="noindex, nofollow" />
    <title>{title} — WikiLeighs</title>
  </head>
  <body>
    <TopBar />
    <div class="page-shell">
      <aside class="left-rail">
        <LeftRail activeType={activeType} />
      </aside>
      <main class="main-col">
        <slot />
      </main>
    </div>
    <footer class="page-footer">
      WikiLeighs · content rendered from <code>notes/</code> in leigh-vault · <a href={`${BASE_URL}about`}>About</a> · <a href={`${BASE_URL}random`}>Random article</a>
    </footer>
  </body>
</html>
