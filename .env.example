# WikiLeighs reads notes from a local Obsidian vault.
# Set VAULT_ROOT to the absolute path of the vault root (the directory that contains notes/).
#
# macOS / Linux:
#   export VAULT_ROOT=/Users/you/Projects/vault
#
# Windows (PowerShell, persistent):
#   setx VAULT_ROOT "C:/Users/you/Documents/leigh-vault"
#
# Use forward slashes on Windows — fast-glob expects POSIX-style paths.
#
# Leigh's machines:
#   Mac:     /Users/leighllewelyn/Projects/vault
#   Desktop: C:/Users/leigh/Documents/leigh-vault
VAULT_ROOT=
